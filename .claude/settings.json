{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prevent-push.sh"
          }
        ]
      },
	  {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/catalog-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
	"PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/catalog-update.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}