# Copy this file to .env (local dev) and fill in real values.
# .env and .env.prod are gitignored — never commit real secrets.

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=schoolmgmt
POSTGRES_PORT=5432

# --- Backend API ---
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8080

# --- Nginx (local dev only — prod uses fixed 80/443, see docker-compose.prod.yml) ---
NGINX_PORT=8081

# --- JWT (see specs/02-implement-auth.md) ---
# Secret must be at least 32 bytes for HMAC-SHA256. Generate a real one per environment —
# never reuse the same secret across dev/prod.
JWT_SECRET=change-me-at-least-32-bytes-long-please
JWT_ISSUER=SchoolMgmt
JWT_AUDIENCE=SchoolMgmt
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# --- Stripe (pay-online, test mode) — https://dashboard.stripe.com/test/apikeys ---
# SecretKey + PublishableKey are enough to pay via the return path; WebhookSigningSecret
# (whsec_...) is only needed for the /api/webhooks/stripe callback.
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your_secret_here
